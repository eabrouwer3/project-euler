# Database
DATABASE_URL=postgresql://euler:euler@localhost:5432/euler

# Auth.js — generate with: openssl rand -hex 32
AUTH_SECRET=

# Required when behind a reverse proxy
AUTH_TRUST_HOST=true

# GitHub OAuth App (create at github.com/settings/developers)
# Callback URL: http://localhost:5173/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public base URL
ORIGIN=http://localhost:5173

# Code execution runner service
# Unset = use local Docker daemon; set to use the runner service
# Local (docker-compose): RUNNER_URL=http://localhost:3001
# Railway: RUNNER_URL=http://runner.railway.internal:3001
RUNNER_URL=
